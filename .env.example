# Neon Postgres (provisioned by the Vercel integration in production).
# With no DATABASE_URL the site runs in demo mode with fictional content.
# DATABASE_URL=postgres://...

# Demo-mode gate (only used when DATABASE_URL is absent).
PARTY_PASSWORD=change-me

# Bearer token for /api/admin/** (party CRUD for scripts/agents).
# Generate with: openssl rand -hex 24
# ADMIN_API_TOKEN=
